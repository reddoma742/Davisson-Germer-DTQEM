output/
results/
figures/generated/

# Generated images (exclude from tracking)
output/*.png
output/*.jpg
results/*.png
*.jpg
*.jpeg

# But keep the main figures for documentation
!figures/figure_b_eff.png
!figures/figure1.png
!figures/figure2.png

